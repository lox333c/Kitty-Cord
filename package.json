{
  "name": "kittycord",
  "version": "1.0.2",
  "description": "Discord-like messaging application named KittyCord",
  "author": "Rager",
  "main": "main.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/lox333c/Kitty-Cord.git"
  },
  "scripts": {
    "start": "electron .",
    "server": "node server.js",
    "app": "electron .",
    "dist": "electron-builder",
    "publish": "electron-builder -p always"
  },
  "dependencies": {
    "@libsql/client": "^0.17.0",
    "cloudinary": "^1.41.3",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "electron-log": "^5.4.3",
    "electron-updater": "^6.1.1",
    "express": "^4.18.2",
    "multer": "^1.4.5-lts.1",
    "multer-storage-cloudinary": "^4.0.0",
    "socket.io": "^4.6.1",
    "sqlite3": "^5.1.6"
  },
  "devDependencies": {
    "electron": "^25.0.0",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.kittycord.app",
    "productName": "KittyCord",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis",
      "icon": "public/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "files": [
      "**/*",
      "!dist/*"
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "lox333c",
        "repo": "Kitty-Cord"
      }
    ],
    "asar": true
  }
}